# TripMate frontend (Expo) env
#
# Set EXPO_PUBLIC_API_URL to your deployed backend to switch from mock mode
# to the real API. Leave it UNSET to run fully in mock mode (no backend needed).
#
# Local backend:   http://localhost:4000
# Deployed (Render example): https://tripmate-api.onrender.com
EXPO_PUBLIC_API_URL=
