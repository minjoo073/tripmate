{
  "name": "tripmate-tmp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --clear --port $PORT",
    "build:web": "expo export --platform web --output-dir docs --clear && find docs -name '*.html' -exec sed -i '' 's|src=\"/_expo/|src=\"/tripmate/_expo/|g; s|href=\"/favicon\\.ico\"|href=\"/tripmate/favicon.ico\"|g' {} + && sed -i '' 's|</head>|<script>if(location.pathname===\"/tripmate\")location.replace(\"/tripmate/\");</script></head>|' docs/index.html && touch docs/.nojekyll"
  },
  "dependencies": {
    "@expo/cli": "^55.0.28",
    "@expo/metro-runtime": "^55.0.10",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "axios": "^1.16.0",
    "expo": "~54.0.33",
    "expo-constants": "^55.0.15",
    "expo-linking": "^55.0.14",
    "expo-router": "^55.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-reanimated": "^3.16.7",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^55.0.21",
    "typescript": "~5.9.2"
  },
  "private": true
}
